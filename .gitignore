# Todo task: runtime state is ignored selectively by .todo-tasks/.gitignore
# (inbox/, .running/, .archived/, *.log, .version). tasks/ and results/ stay
# tracked so the lifecycle bookkeeping can commit specs/outcomes to trunk.

# Playwright
test-results/
playwright-report/

