{
  "name": "luminous",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.28.1",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "pnpm -r run build",
    "build:all": "pnpm -r run build",
    "test": "pnpm -r --parallel test",
    "lint": "eslint .",
    "dev:next": "pnpm --filter @luminous/server dev -- --config $PWD/luminous.config.json --dir $PWD/.canvases & pnpm --filter @luminous/canvas dev",
    "generate:canvas": "tsx scripts/analyze-solidjs.ts",
    "generate:rtp-canvas": "tsx scripts/build-rtp-canvas.ts",
    "validate:pack": "tsx scripts/validate-pack.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "eslint": "^9.39.3",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^16.5.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
