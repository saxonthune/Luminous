{
  "id": "rtp-statechart",
  "version": "0.1.0",
  "description": "RTP statechart + concepts vocabulary for the property-graph architecture.",
  "nodeKinds": [
    {
      "id": "statechart.region",
      "label": "Region",
      "props": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "initial": { "type": "string" }
        },
        "required": ["description"],
        "additionalProperties": false
      },
      "idTemplate": "region.{name}"
    },
    {
      "id": "statechart.composite",
      "label": "Composite",
      "props": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "initial": { "type": "string" },
          "parallel": { "type": "boolean" }
        },
        "required": ["description"],
        "additionalProperties": false
      },
      "idTemplate": "composite.{path}"
    },
    {
      "id": "statechart.state",
      "label": "State",
      "props": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "surface": { "type": "string" },
          "reads": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["description"],
        "additionalProperties": false
      },
      "idTemplate": "state.{path}"
    },
    {
      "id": "statechart.transition",
      "label": "Transition",
      "props": {
        "type": "object",
        "properties": {
          "event": { "type": "string" },
          "description": { "type": "string" },
          "actions": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["event", "description"],
        "additionalProperties": false
      },
      "idTemplate": "transition.{sourceStateId}.{event}",
      "render": {
        "peek": {
          "type": "badge",
          "value": "{content.event}",
          "tone": "default"
        },
        "card": {
          "type": "card",
          "children": [
            {
              "type": "vstack",
              "gap": "4",
              "children": [
                { "type": "badge", "value": "{content.event}", "tone": "default" },
                {
                  "type": "if",
                  "when": "content.description",
                  "then": { "type": "text", "value": "{content.description}", "style": "caption" }
                },
                {
                  "type": "if",
                  "when": "content.actions.length > 0",
                  "then": {
                    "type": "text",
                    "value": "→ {content.actions | join:', '}",
                    "style": "caption",
                    "tone": "muted"
                  }
                }
              ]
            }
          ]
        }
      }
    },
    {
      "id": "rtp.concept",
      "label": "Concept",
      "props": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "state": { "type": "string" },
          "operationalPrinciple": { "type": "string" }
        },
        "required": ["name", "purpose", "state", "operationalPrinciple"],
        "additionalProperties": false
      },
      "idTemplate": "concept.{normalizedName}",
      "render": {
        "peek": {
          "type": "text",
          "value": "{content.name}",
          "style": "heading"
        },
        "card": {
          "type": "card",
          "children": [
            {
              "type": "vstack",
              "gap": "4",
              "children": [
                { "type": "text", "value": "{content.name}", "style": "heading" },
                {
                  "type": "if",
                  "when": "content.purpose",
                  "then": { "type": "text", "value": "{content.purpose}", "style": "caption" }
                }
              ]
            }
          ]
        },
        "open": {
          "type": "card",
          "children": [
            {
              "type": "vstack",
              "gap": "8",
              "children": [
                { "type": "text", "value": "{content.name}", "style": "heading" },
                {
                  "type": "if",
                  "when": "content.purpose",
                  "then": {
                    "type": "vstack",
                    "gap": "2",
                    "children": [
                      { "type": "text", "value": "Purpose", "style": "caption" },
                      { "type": "text", "value": "{content.purpose}", "style": "body" }
                    ]
                  }
                },
                {
                  "type": "if",
                  "when": "content.state",
                  "then": {
                    "type": "vstack",
                    "gap": "2",
                    "children": [
                      { "type": "text", "value": "State", "style": "caption" },
                      { "type": "text", "value": "{content.state}", "style": "body" }
                    ]
                  }
                },
                {
                  "type": "if",
                  "when": "content.operationalPrinciple",
                  "then": {
                    "type": "vstack",
                    "gap": "2",
                    "children": [
                      { "type": "text", "value": "Operational Principle", "style": "caption" },
                      { "type": "text", "value": "{content.operationalPrinciple}", "style": "body" }
                    ]
                  }
                }
              ]
            }
          ]
        }
      }
    },
    {
      "id": "rtp.action",
      "label": "Action",
      "props": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "signature": { "type": "string" },
          "description": { "type": "string" },
          "conceptId": { "type": "string" }
        },
        "required": ["name", "signature", "description", "conceptId"],
        "additionalProperties": false
      },
      "idTemplate": "action.{conceptId}.{actionName}",
      "render": {
        "peek": {
          "type": "text",
          "value": "{content.signature}",
          "style": "mono"
        },
        "card": {
          "type": "card",
          "children": [
            {
              "type": "vstack",
              "gap": "4",
              "children": [
                { "type": "text", "value": "{content.signature}", "style": "mono" },
                {
                  "type": "if",
                  "when": "content.conceptId",
                  "then": { "type": "chip", "value": "{content.conceptId}", "tone": "default" }
                }
              ]
            }
          ]
        },
        "open": {
          "type": "card",
          "children": [
            {
              "type": "vstack",
              "gap": "8",
              "children": [
                { "type": "text", "value": "{content.signature}", "style": "mono" },
                {
                  "type": "if",
                  "when": "content.description",
                  "then": { "type": "text", "value": "{content.description}", "style": "caption" }
                },
                {
                  "type": "if",
                  "when": "content.conceptId",
                  "then": { "type": "chip", "value": "{content.conceptId}", "tone": "default" }
                }
              ]
            }
          ]
        }
      }
    }
  ],
  "edgeKinds": [
    {
      "id": "statechart.substate-of",
      "label": "Substate of",
      "props": { "type": "object", "additionalProperties": false },
      "directed": true,
      "acceptsSource": ["statechart.composite", "statechart.state"],
      "acceptsTarget": ["statechart.region", "statechart.composite"]
    },
    {
      "id": "statechart.transition",
      "label": "Transition",
      "props": { "type": "object", "additionalProperties": false },
      "directed": true,
      "acceptsSource": ["statechart.composite", "statechart.state"],
      "acceptsTarget": ["statechart.composite", "statechart.state"]
    },
    {
      "id": "statechart.invokes-action",
      "label": "Invokes action",
      "props": { "type": "object", "additionalProperties": false },
      "directed": true,
      "acceptsSource": ["statechart.transition"],
      "acceptsTarget": ["rtp.action"]
    },
    {
      "id": "rtp.belongs-to-concept",
      "label": "Belongs to concept",
      "props": { "type": "object", "additionalProperties": false },
      "directed": true,
      "acceptsSource": ["rtp.action"],
      "acceptsTarget": ["rtp.concept"]
    }
  ],
  "views": [
    {
      "id": "statechart",
      "name": "Statechart",
      "description": "States and transitions with action chips on transitions.",
      "zoomToLevel": [
        { "minZoom": 0,   "level": "peek" },
        { "minZoom": 0.4, "level": "card" },
        { "minZoom": 1.2, "level": "open" },
        { "minZoom": 3.0, "level": "deep" }
      ],
      "nodeRoles": {
        "statechart.region":     "spatial",
        "statechart.composite":  "spatial",
        "statechart.state":      "spatial",
        "statechart.transition": "hidden",
        "rtp.concept":           "hidden",
        "rtp.action":            "latent"
      },
      "edgeRoles": {
        "statechart.substate-of":    "contain",
        "statechart.transition":     "arrow",
        "statechart.invokes-action": "summary",
        "rtp.belongs-to-concept":    "hidden"
      },
      "layers": {
        "transitions":      "on",
        "action-chips":     "on",
        "tag-decorations":  "peek"
      },
      "layout": { "algorithm": "elk" }
    },
    {
      "id": "concept-map",
      "name": "Concept map",
      "description": "Concepts containing their actions; states and transitions hidden.",
      "zoomToLevel": [
        { "minZoom": 0,   "level": "peek" },
        { "minZoom": 0.4, "level": "card" },
        { "minZoom": 1.2, "level": "open" },
        { "minZoom": 3.0, "level": "deep" }
      ],
      "nodeRoles": {
        "statechart.region":     "hidden",
        "statechart.composite":  "hidden",
        "statechart.state":      "hidden",
        "statechart.transition": "hidden",
        "rtp.concept":           "spatial",
        "rtp.action":            "spatial"
      },
      "edgeRoles": {
        "statechart.substate-of":    "hidden",
        "statechart.transition":     "hidden",
        "statechart.invokes-action": "hidden",
        "rtp.belongs-to-concept":    "contain"
      },
      "layers": {
        "orphan-action-highlight": "on"
      },
      "layout": { "algorithm": "force" }
    }
  ],
  "layers": [
    {
      "id": "transitions",
      "name": "Transitions",
      "edgeKinds": ["statechart.transition"],
      "defaultState": "on"
    },
    {
      "id": "action-chips",
      "name": "Action chips",
      "edgeKinds": ["statechart.invokes-action"],
      "defaultState": "on"
    },
    {
      "id": "tag-decorations",
      "name": "State tags",
      "edgeKinds": [],
      "defaultState": "peek"
    },
    {
      "id": "orphan-action-highlight",
      "name": "Highlight orphan actions",
      "edgeKinds": [],
      "defaultState": "on"
    }
  ],
  "disclosure": [
    {
      "kind": "statechart.region",
      "peek": ["description"],
      "card": ["description", "initial"],
      "open": ["description", "initial"],
      "deep": ["description", "initial"]
    },
    {
      "kind": "statechart.composite",
      "peek": ["description"],
      "card": ["description", "tags", "initial"],
      "open": ["description", "tags", "initial", "parallel"],
      "deep": ["description", "tags", "initial", "parallel"]
    },
    {
      "kind": "statechart.state",
      "peek": ["surface"],
      "card": ["surface", "tags"],
      "open": ["surface", "tags", "description", "reads"],
      "deep": ["surface", "tags", "description", "reads"]
    },
    {
      "kind": "statechart.transition",
      "peek": ["event"],
      "card": ["event", "description"],
      "open": ["event", "description", "actions"],
      "deep": ["event", "description", "actions"]
    },
    {
      "kind": "rtp.concept",
      "peek": ["name"],
      "card": ["name", "purpose"],
      "open": ["name", "purpose", "state", "operationalPrinciple"],
      "deep": ["name", "purpose", "state", "operationalPrinciple"]
    },
    {
      "kind": "rtp.action",
      "peek": ["name"],
      "card": ["name", "signature"],
      "open": ["name", "signature", "description", "conceptId"],
      "deep": ["name", "signature", "description", "conceptId"]
    }
  ]
}
