{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "allowImportingTsExtensions": false,
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**", "tests/**"]
}
